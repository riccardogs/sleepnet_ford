{
  "seed": 42,
  "results_folder": "results_ford",
  "num_workers": 8,
  "dataset": {
    "dset_path": "data/forda_originale.npz",
    "max_files": 4921
  },
  "pretraining_params": {
    "batch_size": 256,
    "temperature": 0.1,
    "dropout_rate": 0.2,
    "latent_dim": 128,
    "learning_rate": 0.001,
    "max_epochs": 10,
    "check_interval": 2,
    "min_improvement": 0.01,
    "best_model_pth": "checkpoints_ford/encoder/encoder_"
  },
  "latent_space_params": {
    "umap_enabled": false,
    "pca_enabled": false,
    "tsne_enabled": false,
    "visualize": false,
    "compute_metrics": false,
    "n_clusters": 2,
    "output_image_dir": "latent_space/visualizations",
    "output_metrics_dir": "latent_space/metrics",
    "visualization_fraction": 0.5
  },
  "sup_training_params": {
    "learning_rate": 0.001,
    "max_epochs": 5,
    "dropout_rate": 0.5,
    "check_interval": 1,
    "min_improvement": 0.005,
    "best_model_pth": "checkpoints_ford/classifier/classifier_"
  },
  "experiment_num": 2007,
  
  "augmentations": {
  "TailoredMixup": {
    "p": 0.6,
    "fs": 100,
    "beta": 0.3
  },
  "TimeWarping": {
    "p": 0.6,
    "n_segments": 4,
    "scale_range": [0.6, 1.8]
  },
  "Permutation": {
    "p": 0.6,
    "n_segments": 4
  },
  "RandomZeroMasking": {
    "p": 0.6,
    "range": [80, 200]
  },
  "CutoutResize": {
    "p": 0.6,
    "n_segments": 4
  }
 }
}